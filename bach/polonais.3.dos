#
#	Polonaise from p4 of Alfred book
#
-ac b- -ac e- -t 45
6{
	[-o5 [g [g f]] [g r]       r | [a  [a g ]] [a  r]       r ]
	[-o4 [b [b a]] [b r]       r | [c/ [c/ b]] [c/ r]       r ]
	[-o3 g\        [r [b\ g\]] d | r           [r [f+\ d\]] d ]
}

6{
	[-o5 [b  [a g]]  [b  [a  g]] [a  [g f+]] | [g [d e]]  [d c] [c b\] ]
	[-o4 [d/ [c/ b]] [d/ [c/ b]] [c/ [b a ]] | [b [b c/]] [b a] [a g]  ]
	[-o3 g\          g           [c  d]      | g\          r    r      ]
}

6{
	[-o5 [g [g f]] [g r]       r | [a  [a g ]] [a  r]       r ]
	[-o4 [b [b a]] [b r]       r | [c/ [c/ b]] [c/ r]       r ]
	[-o3 g\        [r [b\ g\]] d | r           [r [f+\ d\]] d ]
}

6{
	[-o5 [b  [a g]]  [b  [a  g]] [a  [g f+]] | [g r]      r          r ]
	[-o4 [d/ [c/ b]] [d/ [c/ b]] [c/ [b a ]] | [b [b d/]] [g [b d/]] g ]
	[-o3 g\          g           [c  d]      | [g [b d/]] [g [b d/]] g ]
}


6{
	[-o5 r         [r [b a]] [b r] | r          [r [c/ b]] [c/ r] ]
	[-o5 r         [r [d c]] [d r] | r          [r [e  d]] [e  r] ]
	[-o3 [d [d c]] [d r]     r     | [c [c b\]] [c r]      r      ]
	[-o2 [b [b a]] [b r]     r     | [a [a b]]  [a r]      r      ]
}

6{
	[-o5 [[f g] f] [b f]  [e      d]  | [d  b\ d  c ] 2c                  ]
	[-o5 [[d e] d] [d d]  [c      b\] | [b\ r  b\ a\] 2a\                 ]
	[-o3 b\        [r b_] [[_b a] b]  | f_            [_f e g f] [e d f e]]
}

3{
	[-o5 [f e g f] 2f                         ]
	[-o4 a         [a- g b a]  g_             ]
	[-o3 [d c e d] [c b=\ d c] [b=\ a\ c b=\] ]
}
3{
	[-o5 [e d f e]   2e ]
	[-o4 _g_         [_gf a g] f_ ]
	[-o3 [c b=\ d c] [b\ a\ c b\] [a\ g\ b\ a\] ]
}
3{
	[-o5 [d c e d_] [_d c e d_] [_d c e d_] ]
	[-o4 2f                     b ]
	[-o3 [b\ b]     [a a\]      [g\ g] ]
}
3{
	[-o5 [_d c e d] [c g]  [f e] ]
	[-o4 _b_        [_b a] [b c/_]]
	[-o3 [f f\] [e=\ e-] [d c] ]
}
3{
	[-o5 [3d d] c_ [_c 3c_] ]
	[-o4 [[_c/ a] b_] [_b a b g]  [a [f e]] ]
	[-o3 [b\ g] [e c] [f f\] ]
}
3{
	[-o5 [_c f\ b\ a\] 2b\]
	[-o4 [d r d c]     2d]
	[-o3 [b\ f] [b f] [b\ a\]]
}

6{
	[-o5 [g [g f]] [g r]       r | [a  [a g ]] [a  r]       r ]
	[-o4 [b [b a]] [b r]       r | [c/ [c/ b]] [c/ r]       r ]
	[-o3 g\        [r [b\ g\]] d | r           [r [f+\ d\]] d ]
}

6{
	[-o5 [b  [a g]]  [b  [a  g]] [a  [g f+]] | [g [d e]]  [d c] [c b\] ]
	[-o4 [d/ [c/ b]] [d/ [c/ b]] [c/ [b a ]] | [b [b c/]] [b a] [a g]  ]
	[-o3 g\          g           [c  d]      | g\          r    r      ]
}

6{
	[-o5 [g [g f]] [g r]       r | [a  [a g ]] [a  r]       r ]
	[-o4 [b [b a]] [b r]       r | [c/ [c/ b]] [c/ r]       r ]
	[-o3 g\        [r [b\ g\]] d | r           [r [f+\ d\]] d ]
}

6{
	[-o5 [b  [a g]]  [b  [a  g]] [a  [g f+]] | [g r]      r          r ]
	[-o4 [d/ [c/ b]] [d/ [c/ b]] [c/ [b a ]] | [b [b d/]] [g [b d/]] g ]
	[-o3 g\          g           [c  d]      | [g [b d/]] [g [b d/]] g ]
}

