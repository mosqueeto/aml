 *	All rights reserved.
 *
 */
 
/*
 * MAIN must be defined for "aml.h"
 */

#define AML
 
#ifdef AML
#define MAIN 1
#endif
#include "aml.h"
static char rcsid[] = "$Id$";
char prompt[] = "%s [-T] [-o outfile] filename\n";

main(argc,argv)
int argc;
char *argv[];
{
	char *ofname = "aml.out";

	program = argv[0];	/* remember name for error messages */
	while( (--argc > 0) && ((*++argv)[0] == '-') ) {
	   switch ((*argv)[1]) {
	    case 'o':
		if( argc ) {
		  ++argv; --argc;
		  ofname = *argv;}
                else
		  error("no output file name specified\n",NULL);
		break;
	    case 't':
	    	trace = 1;
	    	break;
	    default:
		error("illegal option: %s\n",*argv);
		break;
	    }
	}
	if( argc == 1 ) {
		init_io( *argv,ofname );
		song(song_env);
	}
	else {
		printf( prompt, program );
	}
	exit(0);
}

@


